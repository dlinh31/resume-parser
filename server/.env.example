# PostgreSQL (required for index stage and API server)
DATABASE_URL=postgresql://user:password@localhost:5432/resume_parser

# OpenAI (required for bullet embeddings in stage 6)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (required for segment and field_extract stages)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001

# Google Document AI (required for scanned PDFs and images only)
DOCAI_PROJECT_ID=your-gcp-project-id
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=your-processor-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
